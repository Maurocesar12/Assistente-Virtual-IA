# ─── Database ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
# PostgreSQL (produção):
# DATABASE_URL="postgresql://user:pass@host:5432/zapgpt"

# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_segura_de_32_chars_minimo
JWT_EXPIRES_IN=7d

# ─── AI Keys (opcionais — configurados por usuário) ────────
# OPENAI_KEY=sk-...
# OPENAI_ASSISTANT=asst_...
# GEMINI_KEY=AIza...

# ─── SMTP (obrigatório para esqueci a senha) ───────────────
# Gmail: ative "Senhas de app" em Google → Conta → Segurança
#        Use a senha de 16 dígitos gerada, não sua senha normal
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="ZapGPT <seuemail@gmail.com>"
