{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",            // ✅ Correto para Node.js com ESM — era "ESNext"
    "moduleResolution": "NodeNext",  // ✅ Correto para Node.js — era "bundler" (para Vite/webpack)
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}